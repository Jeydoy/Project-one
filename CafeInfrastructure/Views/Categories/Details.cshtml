@model CafeDomain.Model.Category

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Category</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.CategoryName)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.CategoryName)
        </dd>
        <dt class="col-sm-2">
            Продукти в категорії
        </dt>
        <dd class="col-sm-10">
            @if (Model.ProductCategories.Any())
            {
                <ul>
                    @foreach (var pc in Model.ProductCategories)
                    {
                        <li>@pc.Product.Description - @pc.Product.Price грн</li>
                    }
                </ul>
            }
            else
            {
                <span class="text-muted">У цій категорії ще немає продуктів.</span>
            }
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
