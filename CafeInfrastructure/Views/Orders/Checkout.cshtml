@page
@model CafeDomain.Model.Order
@{
    ViewData["Title"] = "Оформлення замовлення";
}

<h2>Оформлення замовлення 🐈‍⬛</h2>

<div class="row">
    <div class="col-md-6">
                <form asp-action="Checkout" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div  class="form-group mb-3">
                <label asp-for"adress" class="control-label">Адреса доставки</label>
                <input asp-for="Adress" class="form-control" placeholder="Вулиця Чорних котиків" />
                <span asp-validation-for="Adress" class="text-danger"></span>
            </div>


            <div class="form-group mb-3">
                <label asp-for"payment" class="control-label">Спосіб оплати</label>
                <select asp-for="Payment" class="form-control">
                    <option value="Готівка">Готівкою при отриманні</option>
                    <option value="Картою">Карткою кур'єру</option>
                    <option value="Онлайн">Онлайн-оплата на сaйті</option>
                </select>
                <span asp-validation-for="Payment" class="text-danger"></span>
                </<div>

                <div class="form-group">
                    <button type="submit" class="btn btn-warning btn-lg">Підтвердити замовлення</button>
                </div>
           </form>
    </div>
</div>


@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
