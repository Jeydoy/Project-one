<!DOCTYPE html>
<html lang="uk" data-theme="blackcat">
<head>
    <link rel="stylesheet" href="~/css/app.min.css" asp-append-version="true" />
</head>
<body class="flex flex-col min-h-screen">
    <header>
        <div class="navbar bg-primary text-primary-content shadow-lg px-4 lg:px-20">
            <div class="flex-1">
                <a class="text-2xl font-serif font-bold italic" asp-controller="Home" asp-action="Index">
                    🐈‍⬛ Під чорним котом
                </a>
            </div>
            <div class="flex-none gap-2">
                <a class="btn btn-ghost" asp-controller="Products" asp-action="Index">Меню</a>
                <div class="dropdown dropdown-end">
                    <label tabindex="0" class="btn btn-ghost btn-circle">
                        <div class="indicator">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
                            <span class="badge badge-sm badge-secondary indicator-item">0</span>
                        </div>
                    </label>
                </div>
            </div>
        </div>
    </header>

    <main class="flex-grow container mx-auto px-4 py-8">
        @RenderBody()
    </main>

    <footer class="footer footer-center p-10 bg-primary text-primary-content mt-auto">
        <div>
            <p class="font-bold">Кафе "Під чорним котом" <br />Смак затишку з 2024</p>
            <p>Copyright © 2026 - Всі права захищені</p>
        </div>
    </footer>
</body>
</html>